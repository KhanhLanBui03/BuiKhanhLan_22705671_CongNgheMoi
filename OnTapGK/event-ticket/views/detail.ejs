<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <title>Chi tiết vé</title>
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: Arial, sans-serif;
            background: #f0f2f5;
            padding: 24px;
        }

        .card {
            background: #fff;
            border-radius: 8px;
            max-width: 480px;
            box-shadow: 0 2px 6px rgba(0, 0, 0, .12);
            overflow: hidden;
        }

        .card img {
            width: 100%;
            max-height: 260px;
            object-fit: cover;
        }

        .card-placeholder {
            width: 100%;
            height: 160px;
            background: #e9ecef;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #aaa;
        }

        .card-body {
            padding: 20px;
        }

        h1 {
            margin-bottom: 16px;
            font-size: 18px;
        }

        .row {
            display: flex;
            padding: 8px 0;
            border-bottom: 1px solid #f0f0f0;
            font-size: 14px;
        }

        .row:last-child {
            border-bottom: none;
        }

        .lbl {
            width: 160px;
            color: #888;
            flex-shrink: 0;
        }

        .val {
            font-weight: 600;
            color: #333;
        }

        .badge {
            display: inline-block;
            padding: 2px 10px;
            border-radius: 12px;
            font-size: 13px;
            font-weight: bold;
        }

        .badge-upcoming {
            background: #d4edda;
            color: #155724;
        }

        .badge-sold {
            background: #cce5ff;
            color: #004085;
        }

        .badge-cancelled {
            background: #f8d7da;
            color: #721c24;
        }

        .badge-vip {
            background: #fff3cd;
            color: #856404;
        }

        .badge-vvip {
            background: #d1ecf1;
            color: #0c5460;
        }

        .badge-std {
            background: #e2e3e5;
            color: #383d41;
        }

        .badge-discount {
            background: #d4edda;
            color: #155724;
        }

        .badge-nodiscount {
            background: #f8f9fa;
            color: #6c757d;
            border: 1px solid #dee2e6;
        }

        .card-footer {
            padding: 14px 20px;
            border-top: 1px solid #eee;
            display: flex;
            gap: 8px;
        }

        .btn {
            padding: 8px 14px;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            font-size: 14px;
            text-decoration: none;
            display: inline-block;
        }

        .btn-warning {
            background: #ffc107;
            color: #212529;
        }

        .btn-danger {
            background: #dc3545;
            color: #fff;
        }

        .btn-secondary {
            background: #6c757d;
            color: #fff;
        }
    </style>
</head>

<body>

    <% const total=(ticket.quantity || 0) * (ticket.pricePerTicket || 0); 
    let discount=0; if (ticket.category==='VIP' &&
        ticket.quantity>= 4) discount = 0.10;
        if (ticket.category === 'VVIP' && ticket.quantity >= 2) discount = 0.15;
        const final = total * (1 - discount);
        const hasDiscount = discount > 0;

        let statusClass = 'badge-upcoming';
        if (ticket.status === 'Sold') statusClass = 'badge-sold';
        if (ticket.status === 'Cancelled') statusClass = 'badge-cancelled';

        let catClass = 'badge-std';
        if (ticket.category === 'VIP') catClass = 'badge-vip';
        if (ticket.category === 'VVIP') catClass = 'badge-vvip';
        %>

        <div class="card">
            <% if (ticket.imageUrl) { %>
                <img src="<%= ticket.imageUrl %>" alt="ticket">
                <% } else { %>
                    <div class="card-placeholder">Không có ảnh</div>
                    <% } %>

                        <div class="card-body">
                            <h1>🎫 <%= ticket.eventName %>
                            </h1>

                            <div class="row">
                                <div class="lbl">Người sở hữu</div>
                                <div class="val">
                                    <%= ticket.holderName %>
                                </div>
                            </div>
                            <div class="row">
                                <div class="lbl">Loại vé</div>
                                <div class="val"><span class="badge <%= catClass %>">
                                        <%= ticket.category %>
                                    </span></div>
                            </div>
                            <div class="row">
                                <div class="lbl">Trạng thái</div>
                                <div class="val"><span class="badge <%= statusClass %>">
                                        <%= ticket.status %>
                                    </span></div>
                            </div>
                            <div class="row">
                                <div class="lbl">Ngày sự kiện</div>
                                <div class="val">
                                    <%= ticket.eventDate %>
                                </div>
                            </div>
                            <div class="row">
                                <div class="lbl">Số lượng</div>
                                <div class="val">
                                    <%= ticket.quantity %>
                                </div>
                            </div>
                            <div class="row">
                                <div class="lbl">Đơn giá</div>
                                <div class="val">
                                    <%= Number(ticket.pricePerTicket).toLocaleString('vi-VN') %> ₫
                                </div>
                            </div>
                            <div class="row">
                                <div class="lbl">Thành tiền</div>
                                <div class="val">
                                    <%= total.toLocaleString('vi-VN') %> ₫
                                </div>
                            </div>
                            <div class="row">
                                <div class="lbl">Giảm giá</div>
                                <div class="val"><span
                                        class="badge <%= hasDiscount ? 'badge-discount' : 'badge-nodiscount' %>">
                                        <%= hasDiscount ? '✅ ' + (discount*100) + '% (' + ticket.category + ')'
                                            : '❌ Không giảm' %>
                                    </span></div>
                            </div>
                            <div class="row">
                                <div class="lbl">Sau giảm giá</div>
                                <div class="val" style="color:#e53935;">
                                    <%= final.toLocaleString('vi-VN') %> ₫
                                </div>
                            </div>
                            <div class="row">
                                <div class="lbl">Ticket ID</div>
                                <div class="val" style="font-size:12px;color:#888;">
                                    <%= ticket.ticketId %>
                                </div>
                            </div>
                        </div>

                        <div class="card-footer">
                            <a href="/form/<%= ticket.ticketId %>" class="btn btn-warning">✏️ Sửa</a>
                            <form method="POST" action="/tickets/delete/<%= ticket.ticketId %>" style="margin:0;"
                                onsubmit="return confirm('Xóa vé này?')">
                                <button type="submit" class="btn btn-danger">🗑️ Xóa</button>
                            </form>
                            <a href="/" class="btn btn-secondary">← Danh sách</a>
                        </div>
        </div>

</body>

</html>