<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <title>Quản lý vé sự kiện</title>
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: Arial, sans-serif;
            background: #f0f2f5;
            padding: 20px;
        }

        h1 {
            margin-bottom: 16px;
        }

        .toolbar {
            display: flex;
            gap: 10px;
            margin-bottom: 20px;
            flex-wrap: wrap;
            align-items: center;
        }

        .toolbar input,
        .toolbar select {
            padding: 8px 12px;
            border: 1px solid #ccc;
            border-radius: 4px;
            font-size: 14px;
        }

        .toolbar input {
            width: 260px;
        }

        .btn {
            padding: 8px 14px;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            font-size: 14px;
            text-decoration: none;
            display: inline-block;
        }

        .btn-primary {
            background: #007bff;
            color: #fff;
        }

        .btn-primary:hover {
            background: #0056b3;
        }

        .btn-danger {
            background: #dc3545;
            color: #fff;
        }

        .btn-danger:hover {
            background: #a71d2a;
        }

        .btn-info {
            background: #17a2b8;
            color: #fff;
        }

        .btn-info:hover {
            background: #0f6674;
        }

        .btn-warning {
            background: #ffc107;
            color: #212529;
        }

        .btn-warning:hover {
            background: #d39e00;
        }

        .cards {
            display: flex;
            flex-wrap: wrap;
            gap: 16px;
        }

        .card {
            background: #fff;
            border-radius: 8px;
            width: 280px;
            box-shadow: 0 2px 6px rgba(0, 0, 0, .12);
            overflow: hidden;
            display: flex;
            flex-direction: column;
        }

        .card img {
            width: 100%;
            height: 160px;
            object-fit: cover;
        }

        .card-placeholder {
            width: 100%;
            height: 160px;
            background: #e9ecef;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #aaa;
            font-size: 13px;
        }

        .card-body {
            padding: 12px;
            flex: 1;
        }

        .card-title {
            font-size: 16px;
            font-weight: bold;
            margin-bottom: 6px;
        }

        .card-row {
            font-size: 13px;
            color: #555;
            margin-bottom: 4px;
        }

        .card-row span {
            font-weight: 600;
            color: #333;
        }

        .badge {
            display: inline-block;
            padding: 2px 8px;
            border-radius: 12px;
            font-size: 12px;
            font-weight: bold;
        }

        .badge-upcoming {
            background: #d4edda;
            color: #155724;
        }

        .badge-sold {
            background: #cce5ff;
            color: #004085;
        }

        .badge-cancelled {
            background: #f8d7da;
            color: #721c24;
        }

        .badge-vip {
            background: #fff3cd;
            color: #856404;
        }

        .badge-vvip {
            background: #d1ecf1;
            color: #0c5460;
        }

        .badge-std {
            background: #e2e3e5;
            color: #383d41;
        }

        .badge-discount {
            background: #d4edda;
            color: #155724;
        }

        .badge-nodiscount {
            background: #f8f9fa;
            color: #6c757d;
            border: 1px solid #dee2e6;
        }

        .card-footer {
            padding: 10px 12px;
            border-top: 1px solid #eee;
            display: flex;
            gap: 6px;
        }

        .empty {
            text-align: center;
            color: #888;
            margin-top: 40px;
            width: 100%;
            font-size: 15px;
        }
    </style>
</head>

<body>

    <h1>🎫 Quản lý vé sự kiện</h1>

    <div class="toolbar">
        <form method="GET" action="/" style="display:flex; gap:10px; flex-wrap:wrap; align-items:center;">
            <input type="text" name="search" placeholder="Tìm tên sự kiện / người sở hữu..."
                value="<%= typeof search !== 'undefined' ? search : '' %>">
            <select name="status">
                <option value="">-- Tất cả trạng thái --</option>
                <option value="Upcoming" <%=(typeof statusFilter !=='undefined' && statusFilter==='Upcoming' )
                    ? 'selected' : '' %>>Upcoming</option>
                <option value="Sold" <%=(typeof statusFilter !=='undefined' && statusFilter==='Sold' ) ? 'selected' : ''
                    %>>Sold</option>
                <option value="Cancelled" <%=(typeof statusFilter !=='undefined' && statusFilter==='Cancelled' )
                    ? 'selected' : '' %>>Cancelled</option>
            </select>
            <button type="submit" class="btn btn-primary">Lọc</button>
            <a href="/" class="btn" style="background:#6c757d;color:#fff;">Reset</a>
        </form>
        <a href="/form" class="btn btn-primary" style="margin-left:auto;">+ Thêm vé</a>
    </div>

    <div class="cards">
        <% if (tickets.length===0) { %>
            <p class="empty">Không có vé nào.</p>
            <% } %>

                <% tickets.forEach(function(t) { 
                    const total=(t.quantity || 0) * (t.pricePerTicket || 0); 
                    let discount=0; if (t.category==='VIP' && t.quantity>= 4) discount = 0.10;
                    if (t.category === 'VVIP' && t.quantity >= 2) discount = 0.15;
                    const final = total * (1 - discount);
                    const hasDiscount = discount > 0;

                    let statusClass = 'badge-upcoming';
                    if (t.status === 'Sold') statusClass = 'badge-sold';
                    if (t.status === 'Cancelled') statusClass = 'badge-cancelled';

                    let catClass = 'badge-std';
                    if (t.category === 'VIP') catClass = 'badge-vip';
                    if (t.category === 'VVIP') catClass = 'badge-vvip';
                    %>
                    <div class="card">
                        <% if (t.imageUrl) { %>
                            <img src="<%= t.imageUrl %>" alt="ticket image">
                            <% } else { %>
                                <div class="card-placeholder">Không có ảnh</div>
                                <% } %>

                                    <div class="card-body">
                                        <div class="card-title">
                                            <%= t.eventName %>
                                        </div>
                                        <div class="card-row">👤 <span>
                                                <%= t.holderName %>
                                            </span></div>
                                        <div class="card-row">
                                            Loại: <span class="badge <%= catClass %>">
                                                <%= t.category %>
                                            </span>
                                            &nbsp; Trạng thái: <span class="badge <%= statusClass %>">
                                                <%= t.status %>
                                            </span>
                                        </div>
                                        <div class="card-row">📅 <span>
                                                <%= t.eventDate %>
                                            </span></div>
                                        <div class="card-row">SL: <span>
                                                <%= t.quantity %>
                                            </span> &nbsp; Đơn giá: <span>
                                                <%= Number(t.pricePerTicket).toLocaleString('vi-VN') %>₫
                                            </span></div>
                                        <div class="card-row">Thành tiền: <span>
                                                <%= total.toLocaleString('vi-VN') %>₫
                                            </span></div>
                                        <div class="card-row">Sau giảm: <span style="color:#e53935;font-weight:bold;">
                                                <%= final.toLocaleString('vi-VN') %>₫
                                            </span></div>
                                        <div style="margin-top:6px;">
                                            <span
                                                class="badge <%= hasDiscount ? 'badge-discount' : 'badge-nodiscount' %>">
                                                <%= hasDiscount ? '✅ Được giảm giá ' + (discount*100) + '%'
                                                    : '❌ Không giảm giá' %>
                                            </span>
                                        </div>
                                    </div>

                                    <div class="card-footer">
                                        <a href="/tickets/<%= t.ticketId %>" class="btn btn-info"
                                            style="font-size:12px;">Chi tiết</a>
                                        <a href="/form/<%= t.ticketId %>" class="btn btn-warning"
                                            style="font-size:12px;">Sửa</a>
                                        <form method="POST" action="/tickets/delete/<%= t.ticketId %>" style="margin:0;"
                                            onsubmit="return confirm('Xóa vé này?')">
                                            <button type="submit" class="btn btn-danger"
                                                style="font-size:12px;">Xóa</button>
                                        </form>
                                    </div>
                    </div>
                    <% }) %>
    </div>

</body>

</html>