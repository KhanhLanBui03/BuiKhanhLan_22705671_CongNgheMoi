<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>

<body>
    <div style="border: 1px solid #ccc; padding: 20px; max-width: 400px; margin: 20px auto;">
        <img src="<%= room.imageUrl %>" style="width: 100%; height: auto; object-fit: cover;"
            alt="<%= room.roomName %>">
        <span style="display: block; margin-top: 10px; font-size: 1.5em; font-weight: bold;">
            <%= room.roomName %>
        </span>
        <p>

            Loại phòng: <%= room.roomType %>
        </p>
        <p>
            Giá/Đêm: <%= room.pricePerNight %>đ
        </p>
        <p>
            Sức chứa: <%= room.capacity %> người
        </p>
        <p>
            Trạng thái: <%= room.status %>
        </p>
    </div>
</body>

</html>