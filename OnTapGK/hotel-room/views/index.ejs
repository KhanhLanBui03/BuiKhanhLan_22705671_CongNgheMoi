<!DOCTYPE html>
<html lang="vi">

<head>
  <meta charset="UTF-8">
  <title>Quản lý phòng</title>
  <style>
    .cards {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      margin-top: 16px;
    }

    .card {
      border: 1px solid #ccc;
      border-radius: 6px;
      width: 220px;
      overflow: hidden;
    }

    .card img {
      width: 100%;
      height: 130px;
      object-fit: cover;
    }

    .card-no-img {
      height: 130px;
      background: #eee;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #999;
    }

    .card-body {
      padding: 10px;
      font-size: 13px;
      line-height: 1.7;
    }

    .card-body b {
      display: block;
      font-size: 14px;
      margin-bottom: 4px;
    }

    .card-footer {
      padding: 8px 10px;
      border-top: 1px solid #eee;
      display: flex;
      gap: 6px;
    }
  </style>
</head>

<body>

  <h2>🏨 Danh sách phòng</h2>

  <form method="GET" action="/rooms" style="display:flex; gap:8px; flex-wrap:wrap;">
    <input type="text" name="search" placeholder="Tìm tên phòng..." value="<%= search %>">
    <select name="roomType">
      <option value="">-- Loại --</option>
      <% ['Standard','Deluxe','Suite'].forEach(t=> { %>
        <option value="<%= t %>" <%=roomType===t?'selected':'' %>><%= t %>
        </option>
        <% }) %>
    </select>
    <select name="status">
      <option value="">-- Trạng thái --</option>
      <% ['Available','Occupied','Maintenance'].forEach(s=> { %>
        <option value="<%= s %>" <%=status===s?'selected':'' %>><%= s %>
        </option>
        <% }) %>
    </select>
    <button type="submit">Lọc</button>
    <a href="/rooms">Reset</a>
    &nbsp;|&nbsp;
    <a href="/rooms/form"><b>+ Thêm phòng</b></a>
  </form>

  <p style="font-size:13px; color:#555; margin-top:8px;">
    Available — Standard: <%= availableCount.Standard %> &nbsp; Deluxe: <%= availableCount.Deluxe %> &nbsp; Suite: <%=
          availableCount.Suite %>
  </p>

  <div class="cards">
    <% if (!rooms.length) { %>
      <p>Không có phòng nào.</p>
      <% } %>
        <% rooms.forEach(r=> {  %>
          <div class="card">
            <% if (r.imageUrl) { %>
              <img src="<%= r.imageUrl %>" alt="">
              <% } else { %>
                <div class="card-no-img">Không có ảnh</div>
                <% } %>
                  <div class="card-body">
                    <b>
                      <%= r.roomName %>
                    </b>
                    Loại: <%= r.roomType %><br>
                    Trạng thái: <%= r.status %><br>
                    Giá/đêm: <%= Number(r.pricePerNight).toLocaleString('vi-VN') %>₫<br>
                    Sức chứa: <%= r.capacity %> người<br>
                    DT 3 đêm: <%= r.revenue3Night.toLocaleString('vi-VN') %>₫
                  </div>
                  <div class="card-footer">
                    <a href="/rooms/detail/<%= r.roomId %>">Chi tiết</a>
                    <a href="/rooms/form/<%= r.roomId %>">Sửa</a>
                    <form method="POST" action="/rooms/delete/<%= r.roomId %>" style="margin:0"
                      onsubmit="return confirm('Xóa?')">
                      <button type="submit">Xóa</button>
                    </form>
                  </div>
          </div>
          <% }) %>
  </div>

</body>

</html>