<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Quản lý Sản phẩm</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Segoe UI', system-ui, sans-serif;
      background: #f0f4f8;
      color: #1e293b;
      min-height: 100vh;
    }

    nav {
      background: linear-gradient(135deg, #1e40af, #3b82f6);
      color: white;
      padding: 0 2rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 60px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.2);
    }
    nav .brand {
      font-size: 1.2rem;
      font-weight: 700;
      display: flex;
      align-items: center;
      gap: 0.5rem;
      text-decoration: none;
      color: white;
    }
    nav a.nav-link {
      color: rgba(255,255,255,0.85);
      text-decoration: none;
      padding: 0.4rem 1rem;
      border-radius: 6px;
      transition: background 0.2s;
      font-size: 0.9rem;
    }
    nav a.nav-link:hover { background: rgba(255,255,255,0.15); color: white; }

    .container { max-width: 1100px; margin: 0 auto; padding: 2rem 1rem; }

    .alert {
      padding: 0.9rem 1.2rem;
      border-radius: 8px;
      margin-bottom: 1.2rem;
      display: flex;
      align-items: center;
      gap: 0.6rem;
      font-size: 0.95rem;
    }
    .alert-success { background: #dcfce7; color: #166534; border-left: 4px solid #22c55e; }
    .alert-error   { background: #fee2e2; color: #991b1b; border-left: 4px solid #ef4444; }

    .card {
      background: white;
      border-radius: 12px;
      padding: 1.5rem;
      box-shadow: 0 1px 6px rgba(0,0,0,0.08);
    }

    .btn {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.5rem 1.1rem;
      border-radius: 7px;
      border: none;
      cursor: pointer;
      font-size: 0.88rem;
      font-weight: 500;
      text-decoration: none;
      transition: all 0.2s;
    }
    .btn-primary   { background: #2563eb; color: white; }
    .btn-primary:hover   { background: #1d4ed8; }
    .btn-success   { background: #16a34a; color: white; }
    .btn-success:hover   { background: #15803d; }
    .btn-warning   { background: #d97706; color: white; }
    .btn-warning:hover   { background: #b45309; }
    .btn-danger    { background: #dc2626; color: white; }
    .btn-danger:hover    { background: #b91c1c; }
    .btn-secondary { background: #e2e8f0; color: #475569; }
    .btn-secondary:hover { background: #cbd5e1; }

    .form-group { margin-bottom: 1.1rem; }
    .form-group label {
      display: block;
      margin-bottom: 0.4rem;
      font-weight: 600;
      font-size: 0.9rem;
      color: #374151;
    }
    .form-control {
      width: 100%;
      padding: 0.6rem 0.9rem;
      border: 1.5px solid #d1d5db;
      border-radius: 7px;
      font-size: 0.95rem;
      transition: border-color 0.2s;
      outline: none;
    }
    .form-control:focus { border-color: #3b82f6; box-shadow: 0 0 0 3px rgba(59,130,246,0.12); }
    .form-control.is-invalid { border-color: #ef4444; }

    .invalid-feedback { color: #dc2626; font-size: 0.82rem; margin-top: 0.3rem; }

    .error-list {
      background: #fee2e2;
      border: 1px solid #fecaca;
      border-radius: 8px;
      padding: 0.9rem 1.2rem;
      margin-bottom: 1.2rem;
      color: #991b1b;
    }
    .error-list ul { margin-left: 1.2rem; margin-top: 0.3rem; }
    .error-list li { font-size: 0.9rem; }

    table { width: 100%; border-collapse: collapse; }
    thead th {
      background: #f8fafc;
      padding: 0.75rem 1rem;
      text-align: left;
      font-size: 0.82rem;
      font-weight: 700;
      text-transform: uppercase;
      color: #64748b;
      border-bottom: 2px solid #e2e8f0;
    }
    tbody tr { border-bottom: 1px solid #f1f5f9; transition: background 0.15s; }
    tbody tr:hover { background: #f8fafc; }
    tbody td { padding: 0.75rem 1rem; font-size: 0.92rem; vertical-align: middle; }

    .product-img {
      width: 54px;
      height: 54px;
      object-fit: cover;
      border-radius: 8px;
      border: 1px solid #e2e8f0;
    }
    .no-img {
      width: 54px; height: 54px;
      background: #f1f5f9;
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #94a3b8;
      font-size: 1.2rem;
    }

    .badge {
      display: inline-block;
      padding: 0.2rem 0.6rem;
      border-radius: 99px;
      font-size: 0.78rem;
      font-weight: 600;
    }
    .badge-green { background: #dcfce7; color: #166534; }
    .badge-red   { background: #fee2e2; color: #991b1b; }

    .page-title {
      font-size: 1.5rem;
      font-weight: 700;
      color: #1e293b;
      margin-bottom: 0.3rem;
    }
    .page-subtitle { color: #64748b; font-size: 0.9rem; margin-bottom: 1.5rem; }

    .actions { display: flex; gap: 0.4rem; flex-wrap: wrap; }

    .search-bar {
      display: flex;
      gap: 0.6rem;
      margin-bottom: 1.2rem;
    }
    .search-bar input { flex: 1; }

    .preview-img {
      max-width: 180px;
      max-height: 180px;
      border-radius: 8px;
      margin-top: 0.6rem;
      border: 1px solid #e2e8f0;
      display: block;
    }

    .detail-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
    }
    .detail-field label { font-weight: 600; color: #64748b; font-size: 0.85rem; }
    .detail-field p { font-size: 1rem; margin-top: 0.2rem; color: #1e293b; }

    @media (max-width: 640px) {
      .detail-grid { grid-template-columns: 1fr; }
      .actions .btn { padding: 0.4rem 0.7rem; font-size: 0.82rem; }
    }
  </style>
</head>
<body>
<nav>
  <a class="brand" href="/"><i class="fas fa-boxes-stacked"></i> Quản lý Sản phẩm</a>
  <div>
    <a class="nav-link" href="/"><i class="fas fa-home"></i> Trang chủ</a>
    <a class="nav-link" href="/products/create"><i class="fas fa-plus"></i> Thêm mới</a>
  </div>
</nav>
<div class="container">
