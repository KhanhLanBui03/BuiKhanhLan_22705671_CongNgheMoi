<%- include('../partials/header') %>

<div style="max-width:600px;margin:0 auto;">
  <div class="page-title"><i class="fas fa-plus-circle"></i> Thêm Sản phẩm mới</div>
  <div class="page-subtitle">Điền thông tin sản phẩm vào form bên dưới</div>

  <% if (errors.length > 0) { %>
    <div class="error-list">
      <strong><i class="fas fa-exclamation-triangle"></i> Vui lòng kiểm tra lại:</strong>
      <ul>
        <% errors.forEach(e => { %><li><%= e %></li><% }) %>
      </ul>
    </div>
  <% } %>

  <div class="card">
    <form action="/products" method="POST" enctype="multipart/form-data">

      <div class="form-group">
        <label for="name"><i class="fas fa-tag"></i> Tên sản phẩm <span style="color:red">*</span></label>
        <input type="text" name="name" id="name" class="form-control <%= errors.length > 0 && !old.name ? 'is-invalid' : '' %>"
               value="<%= old.name || '' %>" placeholder="Nhập tên sản phẩm..." required/>
      </div>

      <div class="form-group">
        <label for="price"><i class="fas fa-dollar-sign"></i> Giá (₫) <span style="color:red">*</span></label>
        <input type="number" name="price" id="price" class="form-control"
               value="<%= old.price || '' %>" placeholder="0" min="0" step="1000" required/>
      </div>

      <div class="form-group">
        <label for="unit_in_stock"><i class="fas fa-warehouse"></i> Số lượng tồn kho <span style="color:red">*</span></label>
        <input type="number" name="unit_in_stock" id="unit_in_stock" class="form-control"
               value="<%= old.unit_in_stock || '' %>" placeholder="0" min="0" required/>
      </div>

      <div class="form-group">
        <label for="image"><i class="fas fa-image"></i> Ảnh sản phẩm</label>
        <input type="file" name="image" id="image" class="form-control"
               accept="image/jpeg,image/png,image/gif,image/webp"
               onchange="previewImage(this)"/>
        <small style="color:#64748b;">Chấp nhận: JPG, PNG, GIF, WebP — tối đa 5MB</small>
        <img id="preview" class="preview-img" style="display:none;"/>
      </div>

      <div style="display:flex;gap:0.8rem;margin-top:1.5rem;">
        <button type="submit" class="btn btn-success">
          <i class="fas fa-save"></i> Lưu sản phẩm
        </button>
        <a href="/" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Quay lại</a>
      </div>
    </form>
  </div>
</div>

<script>
function previewImage(input) {
  const preview = document.getElementById('preview');
  if (input.files && input.files[0]) {
    const reader = new FileReader();
    reader.onload = e => { preview.src = e.target.result; preview.style.display = 'block'; };
    reader.readAsDataURL(input.files[0]);
  }
}
</script>

<%- include('../partials/footer') %>
