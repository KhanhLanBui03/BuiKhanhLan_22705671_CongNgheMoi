<%- include('../partials/header') %>

<% if (message) { %>
  <div class="alert alert-success"><i class="fas fa-check-circle"></i> <%= message %></div>
<% } %>
<% if (error) { %>
  <div class="alert alert-error"><i class="fas fa-exclamation-circle"></i> <%= error %></div>
<% } %>

<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.2rem;">
  <div>
    <div class="page-title"><i class="fas fa-list"></i> Danh sách Sản phẩm</div>
    <div class="page-subtitle">Tổng cộng <%= products.length %> sản phẩm</div>
  </div>
  <a href="/products/create" class="btn btn-primary"><i class="fas fa-plus"></i> Thêm sản phẩm</a>
</div>

<form class="search-bar" method="GET" action="/">
  <input type="text" name="search" class="form-control" placeholder="🔍 Tìm kiếm theo tên sản phẩm..." value="<%= search %>"/>
  <button type="submit" class="btn btn-primary"><i class="fas fa-search"></i> Tìm</button>
  <% if (search) { %>
    <a href="/" class="btn btn-secondary"><i class="fas fa-times"></i> Xóa</a>
  <% } %>
</form>

<div class="card">
  <% if (products.length === 0) { %>
    <div style="text-align:center;padding:3rem;color:#94a3b8;">
      <i class="fas fa-box-open" style="font-size:3rem;margin-bottom:1rem;display:block;"></i>
      <% if (search) { %>
        Không tìm thấy sản phẩm nào khớp với "<strong><%= search %></strong>"
      <% } else { %>
        Chưa có sản phẩm nào. <a href="/products/create">Thêm ngay!</a>
      <% } %>
    </div>
  <% } else { %>
  <table>
    <thead>
      <tr>
        <th>Ảnh</th>
        <th>Tên sản phẩm</th>
        <th>Giá</th>
        <th>Tồn kho</th>
        <th style="text-align:center;">Thao tác</th>
      </tr>
    </thead>
    <tbody>
      <% products.forEach(product => { %>
      <tr>
        <td>
          <% if (product.url_image) { %>
            <img src="<%= product.url_image %>" alt="<%= product.name %>" class="product-img"/>
          <% } else { %>
            <div class="no-img"><i class="fas fa-image"></i></div>
          <% } %>
        </td>
        <td>
          <strong><%= product.name %></strong><br/>
          <small style="color:#94a3b8;font-size:0.78rem;">ID: <%= product.id.substring(0,8) %>...</small>
        </td>
        <td style="font-weight:600;color:#1d4ed8;">
          <%= Number(product.price).toLocaleString('vi-VN') %> ₫
        </td>
        <td>
          <span class="badge <%= product.unit_in_stock > 0 ? 'badge-green' : 'badge-red' %>">
            <%= product.unit_in_stock %> cái
          </span>
        </td>
        <td>
          <div class="actions" style="justify-content:center;">
            <a href="/products/<%= product.id %>" class="btn btn-secondary" title="Xem chi tiết">
              <i class="fas fa-eye"></i>
            </a>
            <a href="/products/<%= product.id %>/edit" class="btn btn-warning" title="Sửa">
              <i class="fas fa-edit"></i>
            </a>
            <form action="/products/<%= product.id %>?_method=DELETE" method="POST"
                  onsubmit="return confirm('Bạn có chắc muốn xóa sản phẩm này?')">
              <button type="submit" class="btn btn-danger" title="Xóa">
                <i class="fas fa-trash"></i>
              </button>
            </form>
          </div>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
  <% } %>
</div>

<%- include('../partials/footer') %>
