<%- include('../partials/header') %>

<div style="max-width:600px;margin:0 auto;">
  <div class="page-title"><i class="fas fa-edit"></i> Sửa Sản phẩm</div>
  <div class="page-subtitle">Cập nhật thông tin cho: <strong><%= product.name %></strong></div>

  <% if (errors.length > 0) { %>
    <div class="error-list">
      <strong><i class="fas fa-exclamation-triangle"></i> Vui lòng kiểm tra lại:</strong>
      <ul>
        <% errors.forEach(e => { %><li><%= e %></li><% }) %>
      </ul>
    </div>
  <% } %>

  <div class="card">
    <form action="/products/<%= product.id %>?_method=PUT" method="POST" enctype="multipart/form-data">

      <div class="form-group">
        <label for="name"><i class="fas fa-tag"></i> Tên sản phẩm <span style="color:red">*</span></label>
        <input type="text" name="name" id="name" class="form-control"
               value="<%= product.name %>" placeholder="Nhập tên sản phẩm..." required/>
      </div>

      <div class="form-group">
        <label for="price"><i class="fas fa-dollar-sign"></i> Giá (₫) <span style="color:red">*</span></label>
        <input type="number" name="price" id="price" class="form-control"
               value="<%= product.price %>" min="0" step="1000" required/>
      </div>

      <div class="form-group">
        <label for="unit_in_stock"><i class="fas fa-warehouse"></i> Số lượng tồn kho <span style="color:red">*</span></label>
        <input type="number" name="unit_in_stock" id="unit_in_stock" class="form-control"
               value="<%= product.unit_in_stock %>" min="0" required/>
      </div>

      <div class="form-group">
        <label><i class="fas fa-image"></i> Ảnh hiện tại</label>
        <% if (product.url_image) { %>
          <div>
            <img src="<%= product.url_image %>" alt="Current" class="preview-img" id="currentImg"/>
          </div>
        <% } else { %>
          <p style="color:#94a3b8;font-style:italic;margin-top:0.3rem;">Chưa có ảnh</p>
        <% } %>
      </div>

      <div class="form-group">
        <label for="image"><i class="fas fa-upload"></i> Thay ảnh mới (để trống nếu giữ nguyên)</label>
        <input type="file" name="image" id="image" class="form-control"
               accept="image/jpeg,image/png,image/gif,image/webp"
               onchange="previewNew(this)"/>
        <small style="color:#64748b;">Chấp nhận: JPG, PNG, GIF, WebP — tối đa 5MB</small>
        <img id="newPreview" class="preview-img" style="display:none;"/>
      </div>

      <div style="display:flex;gap:0.8rem;margin-top:1.5rem;">
        <button type="submit" class="btn btn-warning">
          <i class="fas fa-save"></i> Cập nhật
        </button>
        <a href="/" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Quay lại</a>
        <a href="/products/<%= product.id %>" class="btn btn-secondary">
          <i class="fas fa-eye"></i> Xem chi tiết
        </a>
      </div>
    </form>
  </div>
</div>

<script>
function previewNew(input) {
  const preview = document.getElementById('newPreview');
  const current = document.getElementById('currentImg');
  if (input.files && input.files[0]) {
    const reader = new FileReader();
    reader.onload = e => {
      preview.src = e.target.result;
      preview.style.display = 'block';
      if (current) current.style.opacity = '0.4';
    };
    reader.readAsDataURL(input.files[0]);
  }
}
</script>

<%- include('../partials/footer') %>
